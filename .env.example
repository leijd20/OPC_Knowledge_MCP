# 环境变量配置示例
# 复制此文件为 .env 并修改相应的 token 值

# ============================================
# MCP 用户认证 Token
# ============================================
# 建议使用强随机字符串，至少 32 字符
# 可以使用以下命令生成：
#   openssl rand -hex 32
#   或在线生成器：https://www.random.org/strings/

# 只读用户 Token（只能查询）
USER_ALICE_TOKEN=alice_readonly_token_replace_with_random_string

# 读写用户 Token（可以查询和插入文档）
USER_BOB_TOKEN=bob_readwrite_token_replace_with_random_string

# 管理员 Token（所有权限）
ADMIN_TOKEN=admin_full_access_token_replace_with_random_string

# ============================================
# LightRAG 配置（可选）
# ============================================
# 如果 LightRAG 部署在不同的地址，可以在这里覆盖
# LIGHTRAG_URL=http://192.168.1.100:9621
